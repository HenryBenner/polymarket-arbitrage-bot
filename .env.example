# Existing behavior remains the default. Use odahoa_ladder only in a separate
# paper configuration until its fills have been verified.
STRATEGY_MODE=reverse

# dry_run = intent logs, paper = fill-aware simulation, live = real orders.
# When omitted, the legacy DRY_RUN setting below is still honored.
# EXECUTION_MODE=dry_run

# Poll active 15m markets every N ms
POLL_INTERVAL_MS=5000

# Markets to trade (comma-separated slug prefixes)
MARKET_SLUG_PREFIXES=btc-updown-15m,eth-updown-15m

# Reverse side: limit BUY at 7-10c on the cheap (underdog) outcome
CHEAP_BUY_MIN=0.07
CHEAP_BUY_MAX=0.10
CHEAP_ORDER_USDC=10

# Hedge side: limit BUY at 90-95c on the favorite outcome
ENABLE_EXPENSIVE_HEDGE=true
EXPENSIVE_BUY_MIN=0.90
EXPENSIVE_BUY_MAX=0.95
EXPENSIVE_ORDER_USDC=50

# Max shares per order (@odahoa typically uses ~90)
MAX_SHARES_PER_ORDER=90

# Only trade when this many minutes remain in the 15m window (0-15)
MINUTES_BEFORE_CLOSE_MIN=0
MINUTES_BEFORE_CLOSE_MAX=15

# Safety: dry-run is the default. Live trading also requires LIVE_TRADING_ACK.
DRY_RUN=true
LIVE_TRADING_ACK=

# Timed ladder settings (used only with STRATEGY_MODE=odahoa_ladder)
LADDER_PRESET=odahoa_v1
LADDER_SIZE_SCALE=1
LADDER_LIVE_MAX_USDC_PER_MARKET=65
PAPER_STARTING_USDC=100
PAPER_STATE_PATH=./data/paper
LADDER_LIVE_ACK=

# CLOB / wallet (required when DRY_RUN=false)
# Type 3 (POLY_1271): the owner/session-signer key and deposit wallet address.
PRIVATE_KEY=0x...
FUNDER_ADDRESS=0x...
SIGNATURE_TYPE=3
CLOB_HOST=https://clob.polymarket.com
CHAIN_ID=137

# Optional: reuse existing API credentials instead of deriving
# CLOB_API_KEY=
# CLOB_SECRET=
# CLOB_PASSPHRASE=
